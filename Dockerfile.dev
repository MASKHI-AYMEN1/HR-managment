# Dockerfile pour le mode développement avec hot reload
FROM node:20-alpine

WORKDIR /app

# Copier les fichiers de dépendances
COPY package.json package-lock.json* ./

# Installer toutes les dépendances (including devDependencies)
RUN npm ci

# Copier le reste du code
COPY . .

# Exposer le port de développement
EXPOSE 3000

# Lancer en mode développement avec hot reload
# -H 0.0.0.0 pour écouter sur toutes les interfaces (pas seulement localhost)
CMD ["npm", "run", "dev", "--", "-H", "0.0.0.0"]
